{
  "permissions": {
    "allow": [
      "Bash(npm run build:*)",
      "Bash(npm run build)",
      "Bash(npm run validate)",
      "Bash(node scripts/validate-song-data.mjs)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  }
}
